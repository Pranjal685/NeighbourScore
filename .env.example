# Google Maps & Places API (required for healthcare, transport, greenery, crime reverse geocode)
# Enable at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Gemini AI API (for neighborhood narratives)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Project ID
# Found in Firebase Console → Project Settings
FIREBASE_PROJECT_ID=your_firebase_project_id_here

# CPCB Air Quality API (free — register at https://data.gov.in)
CPCB_API_KEY=your_cpcb_api_key_here

# NewsAPI key (for recent crime/safety news in evidence drawer)
# Free tier: 100 requests/day — register at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# Server port (optional, defaults to 3000)
PORT=3000
